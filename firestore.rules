rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user is the specific Admin
    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'waelvts@gmail.com';
    }

    // 1. Events Collection
    match /events/{eventId} {
      // Anyone can read events
      allow read: if true;
      // Only the authenticated admin can create, update, or delete events
      allow write: if isAdmin();
    }

    // 2. Users Collection
    match /users/{userId} {
      // Admin can read/write any profile. Authenticated users can read/write their own profile.
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // 3. Notifications Collection
    match /notifications/{notificationId} {
      // Anyone can read notifications
      allow read: if true;
      // Only the authenticated admin can send or modify notifications
      allow write: if isAdmin();
    }

    // 4. Ad Submissions Collection
    match /ad_submissions/{submissionId} {
      // Anyone can create an ad submission
      allow create: if true;
      // Admin can manage everything, and users can read or update their own submissions
      allow read, update: if isAdmin() || (isSignedIn() && (resource == null || resource.data.advertiserId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // 5. Support Messages Collection
    match /support_messages/{messageId} {
      // Anyone can send support messages
      allow create: if true;
      // Only admin or the author user can read or modify them
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 6. Admin Codes Collection
    match /admin_codes/{codeId} {
      // Anyone can verify if a specific document exists (guessing the code)
      allow get: if true;
      allow list: if false;
      // Only the admin can write or edit codes
      allow write: if isAdmin();
    }

    // 7. Security Violations Collection
    match /security_violations/{violationId} {
      // Anyone can log a security violation
      allow create: if true;
      // Only the admin can read or manage violations
      allow read, update, delete: if isAdmin();
    }
  }
}
