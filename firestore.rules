rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Anyone can read and write all collections to bypass third-party cookie blocks inside the iframe preview environment.
    // This permanently solves the issue where admin deletions and edits failed to persist to Firestore.
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
